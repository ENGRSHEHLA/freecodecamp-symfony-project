{% extends 'base.html.twig' %}


 
{% block body %}
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm p-4">
                <h2 class="mb-4 text-center">Create Account</h2>

                {{ form_start(form) }}

                    {% if form_errors(form) %}
                        <div class="alert alert-danger">
                            {{ form_errors(form) }}
                        </div>
                    {% endif %}

                    <div class="mb-3">
                        <label for="{{ form.username.vars.id }}" class="form-label">Username</label>
                        {{ form_widget(form.username, {'attr': {'class': 'form-control'}}) }}
                        <div class="text-danger">
                            {{ form_errors(form.username) }}
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="{{ form.password.first.vars.id }}" class="form-label">Password</label>
                        {{ form_widget(form.password.first, {'attr': {'class': 'form-control'}}) }}
                        <div class="text-danger">
                            {{ form_errors(form.password.first) }}
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="{{ form.password.second.vars.id }}" class="form-label">Confirm Password</label>
                        {{ form_widget(form.password.second, {'attr': {'class': 'form-control'}}) }}
                        <div class="text-danger">
                            {{ form_errors(form.password.second) }}
                        </div>
                    </div>

                    <div class="d-grid">
                        {{ form_widget(form.register, {
                            'attr': {'class': 'btn btn-primary w-100'},
                            'label': 'Register'
                        }) }}
                    </div>

                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
