{% extends 'base.html.twig' %}

{# {% block title %}Hello PostController!{% endblock %} #}

{% block body %}

 {% for message in app.flashes('success') %}
            <div class="alert alert-success">
                {{ message }}
            </div>
        {% endfor %}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">List of all posts</h1>
    <a href="{{ path('app_post.app_post_create') }}" class="btn btn-primary">Create Post</a>
</div>
<table class="table">
    <thead>
        <tr>
           <td>ID</td>
           <td>Title</td>
           <td>Image</td>
           <td>Category</td>
           <td>Actions</td>
        </tr>
    </thead>
    <tbody>
        {% for post in posts %}

           <tr>
           <td>{{ post.id }}</td>
           <td>
           <a href="{{ path('app_post.show', {'id': post.id}) }}">
            {{ post.title }}
           </a>
         </td>
        <td>
            {% if post.image %}
                <img src="{{ asset('uploads/images/' ~ post.image) }}" alt="{{ post.title }}" class="img-thumbnail" style="max-width: 100px;">
          No image available
            {% endif %}
        </td>
        <td>
            {{ post.category }}
        </td>
        <td>
        <a href="{{ path('app_post.edit', {'id': post.id}) }}" class="btn btn-sm btn-warning mr-2">Edit</a>
    <form method="post" action="{{ path('app_post.delete', {'id': post.id}) }}" onsubmit="return confirm('Are you sure you want to delete this post?')" style="display:inline-block;">
      <button type="submit" class="btn btn-danger">Delete</button>
    </form>
</td>
         </tr>
        {% endfor %}
    </tbody>


{% endblock %}
