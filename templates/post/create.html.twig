{% extends 'base.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .post-create-wrap {
            max-width: 760px;
            margin: 0 auto;
        }

        .post-create-card {
            border: 0;
            border-radius: 14px;
            box-shadow: 0 12px 30px rgba(13, 31, 45, 0.12);
            overflow: hidden;
        }

        .post-create-header {
            background: linear-gradient(120deg, #0f4c75, #3282b8);
            color: #fff;
            padding: 1.25rem 1.5rem;
        }

        .post-create-body {
            background: #f8fafc;
            padding: 1.5rem;
        }

        .form-hint {
            color: #5f6b7a;
            font-size: 0.9rem;
            margin-bottom: 1rem;
        }
    </style>
{% endblock %}

{% block body %}
    <div class="post-create-wrap">
        {% for message in app.flashes('error') %}
            <div class="alert alert-danger">{{ message }}</div>
        {% endfor %}

        {% for message in app.flashes('success') %}
            <div class="alert alert-success">{{ message }}</div>
        {% endfor %}

        <div class="card post-create-card">
            <div class="post-create-header">
                <h2 class="mb-1">{{ page_title|default('Create New Post') }}</h2>
                <p class="mb-0">{{ page_subtitle|default('Add title, category, and optional image for your post.') }}</p>
            </div>

            <div class="post-create-body">
                <p class="form-hint">Fields marked with * are important for better listing quality.</p>

                {{ form_start(form) }}
                    <div class="mb-3">
                        {{ form_label(form.title) }}
                        {{ form_widget(form.title, {'attr': {'class': 'form-control form-control-lg', 'placeholder': 'Ex: Summer T-Shirt Sale'}}) }}
                        {{ form_errors(form.title) }}
                    </div>

                    <div class="mb-3">
                        {{ form_label(form.category) }}
                        {{ form_widget(form.category, {'attr': {'class': 'form-control'}}) }}
                        {{ form_errors(form.category) }}
                    </div>

                    <div class="mb-4">
                        {{ form_label(form.image) }}
                        {{ form_widget(form.image, {'attr': {'class': 'form-control-file'}}) }}
                        {{ form_errors(form.image) }}
                    </div>

                    <div class="d-flex justify-content-between align-items-center">
                        <a href="{{ path('app_post.index') }}" class="btn btn-outline-secondary">Back to posts</a>
                        {{ form_widget(form.save, {'label': submit_label|default('Create Post'), 'attr': {'class': 'btn btn-primary px-4'}}) }}
                    </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>

{% endblock %}